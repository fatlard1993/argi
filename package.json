{
	"name": "argi-cli",
	"version": "1.0.0",
	"description": "A CLI argument parser built around one constraint: every argument is declared before it is parsed.",
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"types": "./index.d.ts",
	"files": [
		"/src/**/*",
		"!/src/**/*.test.js",
		"index.js",
		"index.d.ts"
	],
	"scripts": {
		"test": "bun test",
		"lint": "bun --bun eslint",
		"lint:fix": "bun --bun eslint --fix",
		"format": "bun run lint:fix && bun --bun prettier --write . | grep -q unchanged",
		"analyze": "bun run devTools/bundle-analysis.js",
		"version": "npm version"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fatlard1993/argi.git"
	},
	"author": "justfatlard",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/fatlard1993/argi/issues"
	},
	"homepage": "https://github.com/fatlard1993/argi#readme",
	"keywords": [
		"cli",
		"parser",
		"arguments",
		"command-line",
		"flags",
		"options",
		"validation",
		"lightweight"
	],
	"engines": {
		"node": ">=18.0.0",
		"bun": ">=1.0.0"
	},
	"dependencies": {},
	"devDependencies": {
		"@eslint/js": "^9",
		"bun-types": "^1.3.14",
		"eslint": "^9",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^63.0.2",
		"eslint-plugin-spellcheck": "0.0.20",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-write-good-comments": "^0.2.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3"
	}
}
