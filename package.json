{
	"name": "argi",
	"version": "0.5.2",
	"description": "Lightweight, flexible CLI argument parser with built-in validation and type conversion",
	"type": "module",
	"exports": {
		".": "./index.js"
	},
	"files": [
		"/src/**/*",
		"!/src/**/*.test.js",
		"index.js"
	],
	"scripts": {
		"test": "bun test",
		"lld": "lldtdd run \"lld/*.lld.md\"",
		"lld:lint": "lldtdd lint \"lld/*.lld.md\"",
		"lint": "bun --bun eslint",
		"lint:fix": "bun --bun eslint --fix",
		"format": "bun run lint:fix && bun --bun prettier --write . | grep -q unchanged",
		"analyze": "bun run devTools/bundle-analysis.js",
		"version": "npm version"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fatlard1993/argi.git"
	},
	"author": "justfatlard",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/fatlard1993/argi/issues"
	},
	"homepage": "https://github.com/fatlard1993/argi#readme",
	"keywords": [
		"cli",
		"parser",
		"arguments",
		"command-line",
		"flags",
		"options",
		"validation",
		"lightweight"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"dependencies": {},
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"bun-types": "^1.2.20",
		"eslint": "^9.33.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^54.0.0",
		"eslint-plugin-spellcheck": "0.0.20",
		"eslint-plugin-unicorn": "^60.0.0",
		"eslint-plugin-write-good-comments": "^0.2.0",
		"globals": "^16.3.0",
		"lldtdd": "file:../lldtdd",
		"prettier": "^3.6.2"
	}
}
